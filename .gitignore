## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Original source: https://github.com/github/gitignore/blob/master/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (DotSettings)
*.DotSettings.user

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]lease/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
Log/
[Ll]og/

# Visual Studio 2015/2017 cache/options directory
.vs/
# Uncomment if you use Visual Studio Code
.vscode/

# Environment Variables
.env
.env.development
.env.local
.env.*.local

# SQL Server files
*.mdf
*.ldf
*.ndf

# Others
appsettings.Local.json
appsettings.Development.json
[Bb]uild_errors.txt
[Bb]uild_errors_utf8.txt
To-doListDB.sql
