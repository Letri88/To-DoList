@model IEnumerable<To_doList.Models.TodoTask>

@{
    ViewData["Title"] = "Trash";
}

<div class="container animate-fade-in" style="max-width: 800px;">
    <div class="mb-4 d-flex justify-content-between align-items-center">
        <h1><i class="fas fa-trash-alt me-2 text-danger"></i>Trash</h1>
        <a asp-action="Index" class="btn btn-secondary">&larr; Back to Tasks</a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center text-muted py-5 card">
            <i class="fas fa-trash-restore fa-3x mb-3"></i>
            <p>Trash is empty.</p>
        </div>
    }
    else
    {
        <div class="card">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Task</th>
                            <th>Deleted Date</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="fw-bold">@item.Title</div>
                                    <small class="text-muted text-truncate d-block" style="max-width: 300px;">@item.Description</small>
                                </td>
                                <td>
                                    <!-- Using CreatedAt as proxy for Deleted time since we don't track DeletedAt yet, or could just show original CreatedAt -->
                                    <!-- For now, showing nothing or CreatedAt -->
                                    @item.CreatedAt.ToShortDateString()
                                </td>
                                <td class="text-end">
                                    <form asp-action="Restore" asp-route-id="@item.TaskId" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-success" title="Restore">
                                            <i class="fas fa-undo"></i> Restore
                                        </button>
                                    </form>
                                    <form asp-action="DeletePermanent" asp-route-id="@item.TaskId" method="post" class="d-inline" onsubmit="return confirm('Do you really want to permanently delete this task? This cannot be undone.');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger ms-1" title="Delete Permanently">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
