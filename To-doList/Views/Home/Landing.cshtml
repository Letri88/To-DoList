@{
    ViewData["Title"] = "Welcome";
}
<div class="container text-center" style="margin-top: 5rem;">
    <h1 style="font-size: 3.5rem; font-weight: 800; background: linear-gradient(90deg, var(--primary-color), var(--secondary-color)); -webkit-background-clip: text; color: transparent;">
        To nhưng không Do 🚀
    </h1>
    <p class="text-muted" style="font-size: 1.25rem; max-width: 600px; margin: 1.5rem auto;">
        Nâng cao năng suất làm việc của bạn với nền tảng lập kế hoạch toàn diện. Tích hợp Quản lý Task, Gantt Chart, và Đồng hồ Pomodoro trong một.
    </p>
    <div style="margin-top: 3rem;">
        <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-lg" style="margin-right: 1rem; padding: 0.75rem 2rem; font-size: 1.1rem;">Bắt đầu Miễn phí</a>
        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary btn-lg" style="padding: 0.75rem 2rem; font-size: 1.1rem;">Đăng nhập</a>
    </div>
    
     @*<div style="margin-top: 5rem; margin-bottom: 5rem;">
         <img src="https://images.unsplash.com/photo-1507925922883-d4e9f08ca5d0?q=80&w=1200" alt="Productivity" style="width: 100%; max-width: 800px; border-radius: 16px; box-shadow: var(--shadow-xl);" />
    </div>*@
</div>
