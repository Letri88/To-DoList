@model IEnumerable<To_doList.Models.Tag>

@{
    ViewData["Title"] = "Manage Tags";
}

<div class="container animate-fade-in" style="max-width: 800px;">
    <div class="d-flex justify-between align-center mb-4">
        <div>
            <h1>Tags</h1>
            <p class="text-muted">Categorize your tasks with colorful tags</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            New Tag
        </a>
    </div>

    <div class="card">
        @if (!Model.Any())
        {
            <div style="text-align: center; padding: 2rem; color: var(--text-secondary);">
                <p>No tags created yet. Create one to organize your tasks!</p>
            </div>
        }
        else
        {
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="border-bottom: 1px solid var(--border-color); text-align: left;">
                        <th style="padding: 1rem;">Tag Name</th>
                        <th style="padding: 1rem;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr style="border-bottom: 1px solid var(--border-color);">
                            <td style="padding: 1rem;">
                                <span class="badge" style="background-color: @(item.Color ?? "#e2e8f0"); color: #1e293b; border: 1px solid rgba(0,0,0,0.1);">
                                    @item.TagName
                                </span>
                            </td>
                            <td style="padding: 1rem;">
                                <a asp-action="Edit" asp-route-id="@item.TagId" class="btn btn-secondary btn-sm" style="margin-right: 0.5rem;">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.TagId" class="btn btn-danger btn-sm">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
