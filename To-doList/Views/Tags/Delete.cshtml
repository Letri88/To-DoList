@model To_doList.Models.Tag

@{
    ViewData["Title"] = "Delete Tag";
}

<div class="container animate-fade-in" style="max-width: 500px; text-align: center; margin-top: 4rem;">
    <div class="card">
        <h1 class="text-danger" style="margin-bottom: 1rem;">Delete Tag?</h1>
        <p class="text-muted" style="margin-bottom: 2rem;">Are you sure you want to delete <strong>"@Model.TagName"</strong>? Providing this tag is not used in any task.</p>
        
        <form asp-action="Delete">
            <input type="hidden" asp-for="TagId" />
            <div class="d-flex gap-2 justify-between">
                <a asp-action="Index" class="btn btn-secondary" style="width: 50%;">Cancel</a>
                <button type="submit" class="btn btn-danger" style="width: 50%;">Delete It</button>
            </div>
        </form>
    </div>
</div>
