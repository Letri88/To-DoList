@model To_doList.Models.Tag

@{
    ViewData["Title"] = "Edit Tag";
}

<div class="container animate-fade-in" style="max-width: 500px;">
    <div class="mb-4">
        <a asp-action="Index" class="btn btn-secondary" style="margin-bottom: 1rem;">&larr; Back to Tags</a>
        <h1>Edit Tag</h1>
    </div>

    <div class="card">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="TagId" />
            <input type="hidden" asp-for="UserId" />
            
            <div class="form-group">
                <label asp-for="TagName" class="form-label">Name</label>
                <input asp-for="TagName" class="form-control" />
                <span asp-validation-for="TagName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Color" class="form-label">Color Code</label>
                 <div class="d-flex gap-2">
                    <input asp-for="Color" type="color" class="form-control" style="width: 60px; padding: 0.2rem; height: 40px;" />
                    <input type="text" id="colorText" class="form-control" value="@Model.Color" onchange="document.querySelector('[type=color]').value = this.value" />
                </div>
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 1rem;">Save Changes</button>
        </form>
    </div>
</div>

<script>
    document.querySelector('[type=color]').addEventListener('input', function(e) {
        document.getElementById('colorText').value = e.target.value;
    });
</script>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
