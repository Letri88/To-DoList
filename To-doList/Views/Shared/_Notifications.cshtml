@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using To_doList.Data
@using To_doList.Models
@inject AppDbContext _context
@inject UserManager<AppUserModel> _userManager

@{
    var hasNotifications = false;
    var notificationCount = 0;
    List<TodoTask> urgentTasks = new List<TodoTask>();
    List<TodoTask> assignedTasks = new List<TodoTask>();

    if (User.Identity?.IsAuthenticated ?? false)
    {
        var userId = _userManager.GetUserId(User);
        var now = DateTime.Now;
        
        // Tasks due today or overdue, not completed
        urgentTasks = await _context.Tasks
            .Where(t => t.UserId == userId && !t.IsCompleted && t.DueDate.HasValue && t.DueDate.Value.Date <= now.Date.AddDays(1))
            .OrderBy(t => t.DueDate)
            .Take(5)
            .ToListAsync();

        // Tasks assigned to me by others
        assignedTasks = await _context.TaskAssignments
            .Include(a => a.Task)
            .ThenInclude(t => t.User) // to get the owner name
            .Where(a => a.UserId == userId && a.Task.UserId != userId && !a.Task.IsCompleted)
            .OrderByDescending(a => a.Task.CreatedAt)
            .Take(5)
            .Select(a => a.Task)
            .ToListAsync();

        notificationCount = urgentTasks.Count + assignedTasks.Count;
        hasNotifications = notificationCount > 0;
    }
}

<div class="dropdown" style="position: relative; margin-right: 1.5rem;">
    <button class="btn btn-secondary" id="notificationBtn" style="padding: 0.5rem; background: transparent; border: none; position: relative;">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
            <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
        </svg>
        @if (hasNotifications)
        {
            <span style="position: absolute; top: 0; right: 0; width: 10px; height: 10px; background-color: var(--danger); border-radius: 50%; border: 2px solid white;"></span>
        }
    </button>
    
    <div id="notificationDropdown" class="card" style="position: absolute; right: 0; top: 120%; width: 300px; display: none; z-index: 1000; padding: 0.5rem; box-shadow: var(--shadow-lg);">
        <h4 style="padding: 0.5rem 1rem; margin: 0; font-size: 1rem; border-bottom: 1px solid var(--border-color);">
            Notifications (@notificationCount)
        </h4>
        @if (hasNotifications)
        {
            <div style="max-height: 400px; overflow-y: auto;">
                <!-- Assigned by others notifications -->
                @foreach (var task in assignedTasks)
                {
                    <a asp-controller="Tasks" asp-action="Edit" asp-route-id="@task.TaskId" style="display: block; padding: 0.75rem 1rem; text-decoration: none; color: inherit; border-bottom: 1px solid var(--border-color); transition: background 0.2s; background: rgba(59, 130, 246, 0.05);">
                        <div style="font-weight: 600; font-size: 0.9rem;">
                            <span style="color: var(--primary-color);">🔔 Bạn được giao việc:</span> @task.Title
                        </div>
                        <div style="font-size: 0.8rem; color: var(--text-secondary); margin-top: 4px;">
                            Từ: @(task.User?.UserName ?? "Ai đó")
                        </div>
                    </a>
                }
                
                <!-- Urgent deadlines notifications -->
                @foreach (var task in urgentTasks)
                {
                    <a asp-controller="Tasks" asp-action="Edit" asp-route-id="@task.TaskId" style="display: block; padding: 0.75rem 1rem; text-decoration: none; color: inherit; border-bottom: 1px solid var(--border-color); transition: background 0.2s;">
                        <div style="font-weight: 600; font-size: 0.9rem;">@task.Title</div>
                        <div style="font-size: 0.8rem; color: @(task.DueDate.Value < DateTime.Now ? "var(--danger)" : "var(--warning)");">
                            @(task.DueDate.Value < DateTime.Now ? "Quá hạn" : "Sắp tới hạn"): @task.DueDate.Value.ToString("MMM dd")
                        </div>
                    </a>
                }
            </div>
        }
        else
        {
            <div style="padding: 1.5rem; text-align: center; color: var(--text-secondary);">
                No new notifications
            </div>
        }
    </div>
</div>

<script>
    document.getElementById('notificationBtn').addEventListener('click', function(e) {
        e.stopPropagation();
        var dropdown = document.getElementById('notificationDropdown');
        dropdown.style.display = dropdown.style.display === 'none' ? 'block' : 'none';
    });

    document.addEventListener('click', function() {
        document.getElementById('notificationDropdown').style.display = 'none';
    });
    
    document.getElementById('notificationDropdown').addEventListener('click', function(e) {
        e.stopPropagation();
    });
</script>
